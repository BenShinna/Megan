---
import slateConfig from '~@/slate.config';
import Avatar from '../Avatar/Avatar.astro';

interface Props {
  avatar?: string;
  avatarBack?: string;
}

const {
  avatar = slateConfig.avatar!,
  avatarBack = slateConfig.avatarBack || slateConfig.avatar!
} = Astro.props;
---

<header>
  <div class="mb-9">
    <Avatar
      frontSrc={avatar}
      backSrc={avatarBack}
      alt={slateConfig.title}
      size={56}
    />
  </div>
</header>