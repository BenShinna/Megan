---
import slateConfig from '~@/slate.config';
import Avatar from '../Avatar/index.tsx';

interface Props {
  avatar?: string;
  avatarBack?: string;
}

const { 
  avatar = slateConfig.avatar!,           // ← 加 !
  avatarBack = slateConfig.avatarBack || slateConfig.avatar!  // ← 加 !
} = Astro.props;
---

<header>
  <a href="/" class="mb-9 block whitespace-nowrap text-[0px]">
    <Avatar 
      frontSrc={avatar}
      backSrc={avatarBack}
      alt={slateConfig.title}
      size={56}
      client:load
    />
  </a>
</header>