---
import trainSvg from "@/assets/train.svg?raw";
---

<div class="window">
  <div class="dennchuu" set:html={trainSvg}></div>
  <div class="curtain"></div>
</div>

<style>
.window{
  flex:1;
  height:150px;

  position:relative;

  background:#FDFCFA;
  border-radius:24px;

  overflow:hidden !important;
  background-clip:padding-box;
  -webkit-mask-image:-webkit-radial-gradient(white, black);

  border:1px solid rgba(0,0,0,.05);
  box-shadow:0 4px 20px rgba(0,0,0,.02);
}

.dennchuu {
  position: absolute;
  
  /* 【核心修改】：利用 calc 配合 50% 保证旋转大容器的【几何中心】正好卡在窗口内部 */
  /* 这样旋转的时候，圆环的弧度才会完美出现在窗口里 */
  left: calc(50% - 2500px); 
  top: calc(50% - 2500px); 
  
  width: 5000px;  
  height: 5000px;
  
  /* 确保旋转的轴心是在 5000px 大方块的正中央 */
  transform-origin: center center; 
  
  animation: dennchuu 10s linear infinite;
}


.dennchuu :global(svg) {
  width: 100%;
  height: 100%;
  display: block;
}

.curtain{
  position:absolute;
  inset:0;

  background:#1c1c1c;

  transform-origin:top;
  animation:curtain 2s ease-in-out forwards;
}

@keyframes dennchuu{
  from{
    transform:rotate(0deg);
  }
  to{
    transform:rotate(360deg);
  }
}

@keyframes curtain{
  0%{
    transform:scaleY(1);
  }

  100%{
    transform:scaleY(0);
  }
}
</style>