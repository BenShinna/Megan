---
import trainSvg from "@/assets/train.svg?raw";
---

<div class="window">
  <div class="dennchuu" set:html={trainSvg}></div>
  <div class="curtain"></div>
</div>

<style>
.window{
  flex:1;
  height:150px;

  position:relative;
  overflow:hidden;

  background:#FDFCFA;
  border-radius:24px;

  border:1px solid rgba(0,0,0,.05);
  box-shadow:0 4px 20px rgba(0,0,0,.02);
}

.dennchuu{
  position:absolute;

  /* 你原来能显示的尺寸 */
  width:5000px;
  height:5000px;

  /* 关键 */
  left:-2000px;
  top:-30px;

  transform-origin:center center;

  will-change:transform;
  backface-visibility:hidden;
  transform:translateZ(0);

  animation:dennchuu 10s linear infinite;
}

.dennchuu :global(svg){
  width:100%;
  height:100%;
  display:block;
}

.curtain{
  position:absolute;
  inset:0;

  background:#1c1c1c;

  transform-origin:top;
  animation:curtain 2s ease-in-out forwards;
}

@keyframes dennchuu{
  from{
    transform:translateZ(0) rotate(0deg);
  }

  to{
    transform:translateZ(0) rotate(360deg);
  }
}

@keyframes curtain{
  0%{
    transform:scaleY(1);
  }

  100%{
    transform:scaleY(0);
  }
}
</style>