---
import trainSvg from "@/assets/train.svg?raw";
---

<div class="window">
  <div class="dennchuu" set:html={trainSvg}></div>
  <div class="curtain"></div>
</div>

<style>
.window{
  flex:1;
  height:150px;

  position:relative;

  background:#FDFCFA;
  border-radius:24px;

  overflow:hidden !important;
  background-clip:padding-box;
  -webkit-mask-image:-webkit-radial-gradient(white, black);

  border:1px solid rgba(0,0,0,.05);
  box-shadow:0 4px 20px rgba(0,0,0,.02);
}

.dennchuu {
  position: absolute;
  
  /* 1. 让大方块的【左上角】对准窗口的【正中心】 */
  left: 50%;
  top: 50%;
  
  /* 2. 定义容器大小 */
  width: 5000px;  
  height: 5000px;
  
  /* 3. 设置初始旋转和轴心偏移位置 */
  transform-origin: center center;
  transform: translate(-50%, -50%) translate3d(0, -1880px, 0) rotate(0deg);
  
  animation: dennchuu 10s linear infinite;
}

/* 【唯一保留的动画】必须带上平移位置，否则旋转时会大漂移 */
@keyframes dennchuu {
  from {
    transform: translate(-50%, -50%) translate3d(0, -1880px, 0) rotate(0deg);
  }
  to {
    transform: translate(-50%, -50%) translate3d(0, -1880px, 0) rotate(360deg);
  }
}

.dennchuu :global(svg) {
  width: 100%;
  height: 100%;
  display: block;
}

.curtain{
  position:absolute;
  inset:0;

  background:#1c1c1c;

  transform-origin:top;
  animation:curtain 2s ease-in-out forwards;
}

/* ⚠️ 这里删除了原本冲突的第二个 @keyframes dennchuu */

@keyframes curtain{
  0%{
    transform:scaleY(1);
  }
  100%{
    transform:scaleY(0);
  }
}
</style>
