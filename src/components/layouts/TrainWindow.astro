---
import trainSvg from "@/assets/train.svg?raw";
---

<div class="window">
  <div class="dennchuu" set:html={trainSvg}></div>
  <div class="curtain"></div>
</div>

<style>
.window{
  flex:1;
  height:150px;

  position:relative;

  background:#FDFCFA;
  border-radius:24px;

  overflow:hidden !important;
  background-clip:padding-box;
  -webkit-mask-image:-webkit-radial-gradient(white, black);

  border:1px solid rgba(0,0,0,.05);
  box-shadow:0 4px 20px rgba(0,0,0,.02);
}

.dennchuu {
  position: absolute;
  
  /* 👇 修改这里：把方块加大一倍，并调整位置保持中心点不变 */
  left: -4900px;   /* 原 -2400px。计算：100(中心x) - 5000(新半径) */
  top: -2530px;    /* 原 -30px。计算：2470(中心y) - 5000(新半径) */
  
  width: 10000px;  /* 原 5000px */
  height: 10000px; /* 原 5000px */
  
  animation: dennchuu 10s linear infinite;
}

.dennchuu :global(svg){
  width:100%;
  height:100%;
  display:block;
}

.curtain{
  position:absolute;
  inset:0;

  background:#1c1c1c;

  transform-origin:top;
  animation:curtain 2s ease-in-out forwards;
}

@keyframes dennchuu{
  from{
    transform:rotate(0deg);
  }
  to{
    transform:rotate(360deg);
  }
}

@keyframes curtain{
  0%{
    transform:scaleY(1);
  }

  100%{
    transform:scaleY(0);
  }
}
</style>