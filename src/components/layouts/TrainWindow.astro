---
import trainSvg from "@/assets/train.svg?raw";
---

<div class="window">
  <div class="dennchuu" set:html={trainSvg}></div>
  <div class="curtain"></div>
</div>

<style>
.window{
  flex:1;
  height:150px;

  position:relative;
  overflow:hidden;

  background:#FDFCFA;
  border-radius:24px;

  border:1px solid rgba(0,0,0,.05);
  box-shadow:0 4px 20px rgba(0,0,0,.02);
}

.dennchuu{
  position:absolute;

  width:4200px;
  height:4200px;

  left:-1750px;
  top:-2025px;

  transform-origin:center center;

  will-change:transform;
  backface-visibility:hidden;

  animation:dennchuu 22s linear infinite;
}

.dennchuu :global(svg){
  width:100%;
  height:100%;
  display:block;
}

.curtain{
  position:absolute;
  inset:0;

  background:#1c1c1c;

  transform-origin:top;
  animation:curtain 1.8s ease forwards;
}

@keyframes dennchuu{
  from{
    transform:rotate(0deg);
  }

  to{
    transform:rotate(360deg);
  }
}

@keyframes curtain{
  from{
    transform:scaleY(1);
  }

  to{
    transform:scaleY(0);
  }
}
</style>