---
import { getCollection } from 'astro:content';
import i18next from '@/i18n';
import Search from '@/components/search';
import PageLayout from '@/components/layouts/PageLayout.astro';
// import Button from '@/components/button';
import slateConfig from '~@/slate.config';

const postCollection = await getCollection('post', ({ data }) => {
  return import.meta.env.DEV || data.draft !== true;
});

const tagCounts = postCollection.reduce<Record<string, number>>(
  (res, post) => {
    const postTags = post.data.tags;
    if (!postTags || !postTags.length) return res;
    postTags.forEach((tag) => {
      if (tag.trim() === '') return;

      if (res[tag]) {
        res[tag]++;
      } else {
        res[tag] = 1;
      }
    });
    return res;
  },
  {
    [i18next.t('common.all')]: postCollection.length,
  },
);

const tags = Object.keys(tagCounts).map((tag) => ({
  name: tag,
  count: tagCounts[tag],
}));

const posts = [...postCollection]
  .sort((a, b) => {
    // 统一获取日期进行比较，确保排序不会因为字段名不同而失效
    const dateA = (a.data.pubDate || a.data.published || new Date(0)).getTime();
    const dateB = (b.data.pubDate || b.data.published || new Date(0)).getTime();
    return dateB - dateA;
  })
  .map((post) => ({
    id: post.id,
    slug: post.slug,
    // 【核心修改】URL 优先使用自定义的 permalink，确保点击跳转正确
    url: `/blog/${post.data.permalink || post.slug}`,
    data: post.data,    // 预处理一个 displayDate，方便下方 HTML 调用
    displayDate: post.data.pubDate || post.data.published,
  }));
---

<PageLayout>
  <!-- 
    修改说明：
    1. 外层 section 改为 flex-col，并在 sm (桌面端) 改为 row，让 Search 在右边。
    2. items-center 让手机端胶囊居中，sm:items-start 让电脑端胶囊靠左。
  -->
  <section class="relative mb-16 flex flex-col items-center gap-6 sm:flex-row sm:items-start sm:justify-between">
    
    <!-- 左侧：终端胶囊区域 -->
    <!-- 增加 w-full sm:w-auto 确保手机端占满宽度以便居中，电脑端自适应 -->
    <div class="flex w-full flex-col items-center gap-3 sm:w-auto sm:items-start">
      
      <!-- 胶囊 1：标题 (粉色圆点) -->
      <div class="inline-flex w-fit items-center gap-2 rounded-full border border-slate6/30 bg-slate2 px-5 py-2 font-mono text-lg font-semibold text-slate12 shadow-sm transition-all hover:border-slate6/60 hover:shadow-md sm:text-2xl sm:px-6 sm:py-2.5">
        <!-- 脉冲扩散圆点 -->
        <span class="relative flex h-3 w-3 sm:h-3.5 sm:w-3.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-pink-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-3 w-3 sm:h-3.5 sm:w-3.5 bg-pink-500"></span>
        </span>
        <span class="text-pink-500 font-bold">~</span>
        <span class="tracking-wide">{slateConfig.title}</span>
        <span class="text-slate8">$</span>
      </div>

      <!-- 胶囊 2：描述 (蓝色圆点) -->
      <div class="inline-flex w-fit items-center gap-2 rounded-full border border-slate6/30 bg-slate2 px-4 py-1.5 font-mono text-sm text-slate11 shadow-sm transition-all hover:border-slate6/60 hover:shadow-md sm:px-5 sm:py-2 sm:text-base">
        <!-- 脉冲扩散圆点 -->
        <span class="relative flex h-2 w-2 sm:h-2.5 sm:w-2.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 sm:h-2.5 sm:w-2.5 bg-blue-500"></span>
        </span>
        <span class="text-blue-500 font-bold">~</span>
        <span class="tracking-wide">{slateConfig.description}</span>
        <span class="text-slate8">$</span>
      </div>

    </div>

    <!-- 右侧：搜索框 -->
    <!-- 手机端宽度100%，电脑端固定最小宽度 -->
    <div class="w-full sm:w-auto sm:min-w-[240px]">
      <Search client:only="react" className="w-full sm:w-auto" />
    </div>

  </section>
  <section class="mb-16">
    <div class="text-base text-slate12">
      {
        posts.map((item) => (
          <a class="flex cursor-pointer flex-col justify-between rounded-lg py-2.5 transition-all active:scale-[0.995] active:bg-slate4 sm:flex-row sm:items-center sm:px-2 sm:hover:bg-slate3" href={item.url} title={item.data.title}>
            <span class="shrink-0">{item.data.title}</span>
            <span class="mx-8 hidden h-px w-full grow border-t border-dashed border-slate6 sm:flex" />
            <span class="shrink-0 text-slate8">
              {item.displayDate?.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="mb-16">
    <ul class="flex flex-wrap gap-2 text-base text-slate10">
      {
        tags.map(({ name, count }) => (
          <li class="block cursor-pointer rounded-full bg-slate3 px-4 py-2 text-slate10 transition-all hover:bg-slate4 hover:text-slate11">
            {name}
            <sup class="text-[10px] text-slate8">{count}</sup>
          </li>
        ))
      }
    </ul>
  </section>
</PageLayout>